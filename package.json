{
  "name": "nisystemlink-clients-ts",
  "version": "0.1.1",
  "description": "TypeScript API clients for NI SystemLink services, generated from OpenAPI specifications",
  "type": "module",
  "main": "./dist/client.cjs",
  "module": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "files": [
    "dist",
    "src/generated",
    "src/client.ts",
    "tsconfig.json",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "tsx scripts/generate-all.ts",
    "generate:exports": "tsx scripts/generate-exports.ts",
    "prebuild": "tsx scripts/generate-exports.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' tsup",
    "build:watch": "NODE_OPTIONS='--max-old-space-size=8192' tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config test-app/vitest.config.ts",
    "test:watch": "vitest --config test-app/vitest.config.ts",
    "test:ui": "vitest --ui --config test-app/vitest.config.ts",
    "pack": "npm run build && npm pack"
  },
  "keywords": [
    "systemlink",
    "ni",
    "openapi",
    "typescript",
    "sdk"
  ],
  "author": "NI",
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^16.4.7",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
