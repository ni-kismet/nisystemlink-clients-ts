# Environment configuration for SystemLink TypeScript API validation tests
# Copy this file to .env and fill in your values

# Base URL of your SystemLink server (no trailing slash)
# Example: https://myserver.lifecyclesolutions.ni.com
SYSTEMLINK_API_URL=https://your-systemlink-server.example.com

# API key with sufficient permissions to read resources
SYSTEMLINK_API_KEY=your-api-key-here
